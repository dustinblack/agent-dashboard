{# Containerfile template for the Agent Dashboard daemon.
   Agent tool installations, config seeding, and verification
   are driven by profile provisioning metadata. Static
   infrastructure (base packages, gh, gcloud, dev tools)
   is edited directly in this template.

   Generate: python3 generate_containerfile.py
   Build:    podman build -t agent-dashboard-daemon -f Containerfile .
#}
FROM registry.fedoraproject.org/fedora:42

WORKDIR /app

# Install base system packages and development tools
RUN dnf install --setopt=install_weak_deps=False --setopt=retries=3 -y \
    bash \
    bash-completion \
    curl \
    nodejs \
    nodejs-full-i18n \
    npm \
    git \
    openssh-clients \
    less \
    vim-enhanced \
    man-db \
    ca-certificates \
    gnupg2 \
    jq \
    tree \
    procps-ng \
    iputils \
    iproute \
    unzip \
    zip \
    make \
    ripgrep \
    bind-utils \
    diffstat \
    hostname \
    strace \
    tmux \
    file \
    patch \
    wget \
    which \
    podman \
    fuse-overlayfs \
    golang \
    glab \
    rust \
    cargo \
    python3 \
    python3-pip \
    python3-devel \
    gcc \
    slirp4netns \
{% for pkg in system_packages %}
    {{ pkg }} \
{% endfor %}
    && dnf clean all

# Configure podman for containers-in-containers networking.
# Inside a container, netavark's setns() call is denied even with
# --privileged. Using slirp4netns avoids creating new network
# namespaces entirely.
RUN mkdir -p /etc/containers \
    && printf '[network]\ndefault_rootless_network_cmd = "slirp4netns"\n' \
       >> /etc/containers/containers.conf

# Install GitHub CLI
RUN printf '[gh-cli]\nname=GitHub CLI\nbaseurl=https://cli.github.com/packages/rpm\nenabled=1\ngpgcheck=1\ngpgkey=https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x23F3D4EA75716059\n' \
    > /etc/yum.repos.d/gh-cli.repo \
    && dnf install --setopt=install_weak_deps=False --setopt=retries=3 -y gh \
    && dnf clean all

# Install Google Cloud CLI (required for Claude Code via Vertex AI)
# Use direct tarball download with explicit architecture detection to avoid
# the interactive installer script, which may modify shell profiles and
# bundle incompatible Python on some architectures.
RUN ARCH=$(uname -m) \
    && if [ "$ARCH" = "x86_64" ]; then GCLOUD_ARCH="x86_64"; \
       elif [ "$ARCH" = "aarch64" ]; then GCLOUD_ARCH="arm"; \
       else echo "Unsupported architecture: $ARCH" && exit 1; fi \
    && curl -sSL --retry 3 "https://dl.google.com/dl/cloudsdk/channels/rapid/downloads/google-cloud-cli-linux-${GCLOUD_ARCH}.tar.gz" \
       -o /tmp/gcloud.tar.gz \
    && tar -xzf /tmp/gcloud.tar.gz -C /opt \
    && rm /tmp/gcloud.tar.gz \
    && /opt/google-cloud-sdk/install.sh --quiet --usage-reporting false --path-update false --command-completion false \
    && ln -s /opt/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud \
    && ln -s /opt/google-cloud-sdk/bin/gsutil /usr/local/bin/gsutil

# Install Antigravity CLI (agy) — Google's replacement for Gemini CLI.
# The installer drops the Go binary to ~/.local/bin/agy; the symlink
# puts it on the container's default PATH.
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash \
    && ln -sf /root/.local/bin/agy /usr/local/bin/agy

# ── Agent tool installations (profile-driven) ─────
{% if npm_packages %}
RUN npm install -g {{ npm_packages | join(' ') }}
{% endif %}
{% if pip_packages %}
RUN pip3 install --no-cache-dir {{ pip_packages | join(' ') }}
{% endif %}


{% for cf in config_files %}
{% if cf.mkdir and not cf.content %}
RUN mkdir -p {{ cf.path }}
{% elif cf.content %}
RUN mkdir -p $(dirname {{ cf.path }}) && \
    echo '{{ cf.content }}' > {{ cf.path }}
{% endif %}
{% endfor %}
{% if verify_commands %}

# Verify agent CLI installations
RUN {{ verify_commands | join(' && ') }}
{% endif %}

# Install general-purpose Python dev tools for linting and formatting
RUN pip3 install --no-cache-dir black flake8 pylint

# Copy requirements and install daemon python dependencies
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# Copy the daemon as a Python package so imports
# (e.g. from agent.profiles) work correctly.
COPY __init__.py agent/
COPY host_daemon.py agent/
COPY profiles.py agent/
COPY profiles/ agent/profiles/

# Run as a module to preserve package import paths
ENTRYPOINT ["python3", "-m", "agent.host_daemon"]
