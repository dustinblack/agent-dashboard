FROM registry.fedoraproject.org/fedora:42

WORKDIR /app

# Install basic utilities, nodejs, and npm
RUN dnf install --setopt=install_weak_deps=False -y \
    bash \
    curl \
    nodejs \
    npm \
    git \
    openssh-clients \
    less \
    vim-enhanced \
    man-db \
    ca-certificates \
    gnupg2 \
    jq \
    tree \
    procps-ng \
    iputils \
    iproute \
    unzip \
    zip \
    make \
    ripgrep \
    bind-utils \
    strace \
    tmux \
    file \
    patch \
    python3 \
    python3-pip \
    python3-devel \
    gcc \
    && dnf clean all

# Install GitHub CLI
RUN printf '[gh-cli]\nname=GitHub CLI\nbaseurl=https://cli.github.com/packages/rpm\nenabled=1\ngpgcheck=1\ngpgkey=https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x23F3D4EA75716059\n' \
    > /etc/yum.repos.d/gh-cli.repo \
    && dnf install --setopt=install_weak_deps=False -y gh \
    && dnf clean all

# Install Google Cloud CLI (required for Claude Code via Vertex AI)
RUN curl -sSL https://sdk.cloud.google.com > /tmp/install_gcloud.sh \
    && bash /tmp/install_gcloud.sh --disable-prompts --install-dir=/opt \
    && rm /tmp/install_gcloud.sh \
    && ln -s /opt/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud \
    && ln -s /opt/google-cloud-sdk/bin/gsutil /usr/local/bin/gsutil

# Install actual AI CLIs via npm
RUN npm install -g @google/gemini-cli @anthropic-ai/claude-code

# Pre-configure Gemini CLI to skip API key prompt
RUN mkdir -p /root/.gemini && \
    echo '{"security": {"auth": {"selectedType": "gemini-api"}}}' > /root/.gemini/settings.json

# Copy requirements and install daemon python dependencies
COPY requirements.txt .
RUN pip3 install --no-cache-dir -r requirements.txt

# Copy the daemon script
COPY host_daemon.py .

# Use the daemon as the entrypoint
ENTRYPOINT ["python3", "host_daemon.py"]
